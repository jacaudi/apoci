          "refId": "A"
        },
        {
          "expr": "rate(apoci_gc_orphaned_metadata_total{job=\"apoci\"}[5m])",
          "legendFormat": "Orphaned metadata",
          "refId": "B"
        },
        {
          "expr": "rate(apoci_gc_orphaned_files_total{job=\"apoci\"}[5m])",
          "legendFormat": "Orphaned files",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "stacking": { "mode": "none" } }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "type": "timeseries",
      "title": "GC Cycles",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 50 },
      "id": 52,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(apoci_gc_cycles_completed_total{job=\"apoci\"}[5m])",
          "legendFormat": "Cycles/s",
          "refId": "A"
        }
      ],
