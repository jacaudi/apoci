    {
      "type": "row",
      "title": "Garbage Collection",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 49 },
      "id": 50,
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "GC Removals",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 50 },
      "id": 51,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(apoci_gc_stale_peer_blobs_total{job=\"apoci\"}[5m])",
