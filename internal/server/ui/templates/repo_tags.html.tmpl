<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{.Title}}</title>
    <link rel="stylesheet" href="/ui/static/pico.min.css">
    <style>
        .tag-row { margin-bottom: 0.5rem; padding: 1rem; background: var(--pico-card-background-color); border-radius: var(--pico-border-radius); }
        .tag-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem; }
        .tag-name { font-weight: 600; font-size: 1.1em; }
        .tag-meta { font-size: 0.85em; color: var(--pico-muted-color); }
        .pull-cmd { display: flex; align-items: center; gap: 0.5rem; margin-top: 0.5rem; }
        .pull-cmd code { flex: 1; padding: 0.5rem; background: var(--pico-code-background-color); border-radius: var(--pico-border-radius); font-size: 0.85em; overflow-x: auto; white-space: nowrap; }
        .copy-btn { cursor: pointer; padding: 0.4rem 0.6rem; background: var(--pico-secondary-background); border: none; border-radius: var(--pico-border-radius); font-size: 0.8em; }
        .copy-btn:hover { background: var(--pico-secondary-hover-background); }
        .copy-btn.copied { background: var(--pico-ins-color); color: white; }
        .back-link { margin-bottom: 1rem; display: inline-block; }
        .digest { font-family: monospace; font-size: 0.8em; color: var(--pico-muted-color); display: flex; align-items: center; gap: 0.5rem; }
        .copy-btn-small { padding: 0.2rem 0.4rem; font-size: 0.7em; }
        .platform { font-size: 0.8em; color: var(--pico-primary); margin-top: 0.25rem; }
        .scan-badge { display: inline-block; padding: 0.1rem 0.4rem; margin-right: 0.3rem; border-radius: var(--pico-border-radius); font-size: 0.75em; font-weight: 600; color: white; }
        .scan-clean { background: var(--pico-ins-color); }
        .scan-critical { background: #b91c1c; }
        .scan-high { background: #ea580c; }
        .scan-medium { background: #ca8a04; }
        .scan-low { background: #65a30d; }
        .empty-state { text-align: center; padding: 3rem; color: var(--pico-muted-color); }
        .cmd-label { font-size: 0.75em; color: var(--pico-muted-color); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.25rem; }
        .pagination { display: flex; justify-content: center; align-items: center; gap: 1rem; margin-top: 2rem; }
        .pagination a, .pagination span { padding: 0.5rem 1rem; border-radius: var(--pico-border-radius); text-decoration: none; }
        .pagination a { background: var(--pico-secondary-background); color: var(--pico-color); }
        .pagination a:hover { background: var(--pico-secondary-hover-background); }
        .pagination .current { background: var(--pico-primary); color: white; }
        .pagination .disabled { color: var(--pico-muted-color); cursor: not-allowed; }
    </style>
</head>
<body>
    <main class="container">
        <a href="/" class="back-link">&larr; Back to repositories</a>
        <header>
            <h1>{{.RepoName}}</h1>
            <p>{{len .Tags}} tag{{if ne (len .Tags) 1}}s{{end}}</p>
        </header>

        {{if eq (len .Tags) 0}}
        <div class="empty-state">
            <p>No tags found for this repository.</p>
        </div>
        {{else}}
        <section>
            {{range .Tags}}
            <article class="tag-row">
                <div class="tag-header">
                    <span class="tag-name">{{.Name}}</span>
                    <span class="tag-meta">
                        {{if .Scan}}
                            {{if eq .Scan.Total 0}}
                            <span class="scan-badge scan-clean" title="No known vulnerabilities">✓ clean</span>
                            {{else}}
                            {{if gt .Scan.Critical 0}}<span class="scan-badge scan-critical" title="Critical">C {{.Scan.Critical}}</span>{{end}}
                            {{if gt .Scan.High 0}}<span class="scan-badge scan-high" title="High">H {{.Scan.High}}</span>{{end}}
                            {{if gt .Scan.Medium 0}}<span class="scan-badge scan-medium" title="Medium">M {{.Scan.Medium}}</span>{{end}}
                            {{if gt .Scan.Low 0}}<span class="scan-badge scan-low" title="Low">L {{.Scan.Low}}</span>{{end}}
                            {{end}}
                        {{end}}
                        {{.SizeHuman}} &bull; {{.UpdatedAgo}}
                    </span>
                </div>
                <div class="digest">
                    <span>{{.DigestShort}}</span>
                    <button class="copy-btn copy-btn-small" data-copy="{{.Digest}}">Copy</button>
                </div>
                {{if .Platform}}
                <div class="platform">{{.Platform}}</div>
                {{end}}

                <div class="cmd-label">Docker</div>
                <div class="pull-cmd">
                    <code>docker pull {{$.RegistryHost}}/{{$.RepoName}}:{{.Name}}</code>
                    <button class="copy-btn" data-copy="docker pull {{$.RegistryHost}}/{{$.RepoName}}:{{.Name}}">Copy</button>
                </div>
                {{if ne $.RepoName $.FullRepoName}}
                <details>
                    <summary class="cmd-label" style="margin-top: 0.5rem;">Fully-qualified address</summary>
                    <div class="pull-cmd">
                        <code>docker pull {{$.RegistryHost}}/{{$.FullRepoName}}:{{.Name}}</code>
                        <button class="copy-btn" data-copy="docker pull {{$.RegistryHost}}/{{$.FullRepoName}}:{{.Name}}">Copy</button>
                    </div>
                </details>
                {{end}}

                {{if .IsOCI}}
                <div class="cmd-label" style="margin-top: 0.5rem;">OCI Artifact</div>
                <div class="pull-cmd">
                    <code>oras pull {{$.RegistryHost}}/{{$.RepoName}}:{{.Name}}</code>
                    <button class="copy-btn" data-copy="oras pull {{$.RegistryHost}}/{{$.RepoName}}:{{.Name}}">Copy</button>
                </div>
                {{end}}
            </article>
            {{end}}
        </section>

        {{if gt .TotalPages 1}}
        <nav class="pagination">
            {{if .HasPrev}}
            <a href="?page={{subtract .Page 1}}">&larr; Previous</a>
            {{else}}
            <span class="disabled">&larr; Previous</span>
            {{end}}

            <span class="current">Page {{.Page}} of {{.TotalPages}}</span>

            {{if .HasNext}}
            <a href="?page={{add .Page 1}}">Next &rarr;</a>
            {{else}}
            <span class="disabled">Next &rarr;</span>
            {{end}}
        </nav>
        {{end}}
        {{end}}
    </main>
    <script src="/ui/static/copy.js" defer></script>
</body>
</html>
